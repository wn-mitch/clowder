/target
**/*.rs.bk
*.pdb

# Bevy
/assets/**/*.meta

# Saves
/saves

# Logs — ignore contents but preserve the baseline registry
# (labels are committed so other workstations can adopt the same
# baseline; current.json is per-machine and gitignored inside
# logs/baselines/).
/logs/*
!/logs/baselines/

