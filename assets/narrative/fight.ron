[
    // Combat narrative is primarily event-driven from the combat system.
    // These templates fire on action completion (disengage).
    (
        text: "{name} disengages from the fight, panting.",
        tier: Action,
        action: Some(Fight),
    ),
    (
        text: "{name} backs away from the scuffle.",
        tier: Action,
        action: Some(Fight),
    ),
    (
        text: "{name} shakes off the dust and catches {possessive} breath.",
        tier: Action,
        action: Some(Fight),
    ),

    // --- Personality-conditioned ---
    (
        text: "{name} stands {possessive} ground, teeth bared, until the threat retreats.",
        tier: Action,
        action: Some(Fight),
        personality: [(axis: Boldness, bucket: High)],
    ),
    (
        text: "{name} fights with cold precision, wasting no movement.",
        tier: Action,
        action: Some(Fight),
        personality: [(axis: Diligence, bucket: High)],
    ),
    (
        text: "{name} hisses and swipes, more fury than form.",
        tier: Action,
        action: Some(Fight),
        personality: [(axis: Temper, bucket: High)],
    ),
    (
        text: "{name} steps back from the fight, fur bristling, eyes wide.",
        tier: Action,
        action: Some(Fight),
        personality: [(axis: Anxiety, bucket: High)],
    ),

    // --- Weather/mood ---
    (
        text: "{name} fights through the downpour, blinking rain from {possessive} eyes.",
        tier: Action,
        action: Some(Fight),
        weather: Some(HeavyRain),
    ),
    (
        text: "{name} disengages with a victorious yowl.",
        tier: Action,
        action: Some(Fight),
        mood: Some(Happy),
    ),
    (
        text: "{name} limps away from the fray, but alive.",
        tier: Action,
        action: Some(Fight),
        mood: Some(Low),
    ),
    (
        text: "{name} throws {object}self into the fight without hesitation.",
        tier: Action,
        action: Some(Fight),
        personality: [(axis: Boldness, bucket: High)],
        mood: Some(Neutral),
    ),
]
