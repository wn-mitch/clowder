    (
        text: "{name} drives the shadow-fox to its knees. It shrieks, dissolves into mist — gone.",
        tier: Legend,
        event: Some("banishment"),
    ),
    (
        text: "The shadow-fox's form frays at the edges, unravelling into mist. A chorus of breath rises from the colony.",
        tier: Legend,
        event: Some("banishment"),
    ),
    (
        text: "A shriek, a burst of cold wind, and the shadow-fox is gone. {name} stands its ground as the colony breathes.",
        tier: Legend,
        event: Some("banishment"),
    ),
    (
        text: "The shadow-fox's body dissolves mid-lunge, scattered like smoke on a lifting fog. {name} holds the line.",
